{
  "frontend": {
    "display_prefix": "/caferoam/",
    "stack_detection_paths": ["app/", "components/", "lib/"],
    "critical_paths": [
      "app/api/search/route.ts",
      "app/api/checkins/route.ts",
      "app/api/checkins/[id]/review/route.ts",
      "app/api/lists/route.ts",
      "app/api/auth/route.ts",
      "app/api/auth/consent/route.ts",
      "app/api/auth/account/route.ts",
      "app/api/auth/cancel-deletion/route.ts",
      "app/api/profile/route.ts",
      "app/api/shops/[id]/reviews/route.ts",
      "app/api/explore/community/route.ts",
      "app/api/explore/community/[checkinId]/like/route.ts",
      "app/api/explore/tarot-draw/route.ts",
      "app/api/explore/vibes/route.ts",
      "app/api/explore/vibes/[slug]/shops/route.ts",
      "app/api/maps/directions/route.ts",
      "app/api/analytics/events/route.ts",
      "lib/posthog/use-analytics.ts"
    ],
    "critical_patterns": ["app/api/**/route.ts"],
    "critical_threshold": 80,
    "default_threshold": 45,
    "exclude_patterns": [
      "**/*.json",
      "**/index.ts",
      "**/*.d.ts",
      "**/setup.ts",
      "**/*.config.ts",
      "**/*.config.mjs",
      "**/middleware.ts",
      "**/scripts/prebuild/**",
      "**/scripts/generate-pwa-icons.ts",
      "layout.tsx",
      "*/components/ui/*.tsx",
      "**/e2e/**",
      "**/types/*.ts"
    ]
  },
  "backend": {
    "display_prefix": "",
    "stack_detection_paths": [".py"],
    "critical_paths": [
      "services/search_service.py",
      "services/checkin_service.py",
      "services/lists_service.py",
      "services/community_service.py",
      "services/profile_service.py",
      "services/query_classifier.py",
      "services/tarot_service.py",
      "services/vibe_service.py",
      "providers/llm/anthropic_adapter.py",
      "providers/embeddings/openai_adapter.py",
      "providers/email/resend_adapter.py",
      "providers/maps/mapbox_adapter.py",
      "providers/analytics/posthog_adapter.py",
      "providers/scraper/apify_adapter.py",
      "api/auth.py",
      "api/shops.py",
      "api/search.py",
      "api/checkins.py",
      "api/lists.py",
      "api/stamps.py",
      "api/explore.py",
      "api/feed.py",
      "api/maps.py",
      "api/profile.py",
      "api/analytics.py",
      "models/analytics_events.py"
    ],
    "critical_patterns": [
      "services/*.py",
      "providers/**/*_adapter.py",
      "api/*.py"
    ],
    "critical_threshold": 80,
    "default_threshold": 45,
    "exclude_patterns": [
      "**/__init__.py",
      "**/conftest.py",
      "tests/**",
      ".venv/**"
    ]
  }
}
